{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Reader",
  "version": "0.1.0",
  "identifier": "com.balaji.reader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Reader",
        "width": 900,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["epub"],
        "name": "EPUB Book",
        "description": "EPUB ebook",
        "mimeType": "application/epub+zip",
        "role": "Viewer"
      },
      {
        "ext": ["mobi", "azw", "azw3"],
        "name": "Kindle Book",
        "description": "Mobipocket / Kindle ebook",
        "mimeType": "application/x-mobipocket-ebook",
        "role": "Viewer"
      },
      {
        "ext": ["fb2", "fbz"],
        "name": "FictionBook",
        "description": "FictionBook ebook",
        "mimeType": "application/x-fictionbook+xml",
        "role": "Viewer"
      },
      {
        "ext": ["cbz"],
        "name": "Comic Book",
        "description": "Comic book archive",
        "mimeType": "application/vnd.comicbook+zip",
        "role": "Viewer"
      },
      {
        "ext": ["pdf"],
        "name": "PDF",
        "description": "PDF document",
        "mimeType": "application/pdf",
        "role": "Viewer"
      }
    ]
  }
}
